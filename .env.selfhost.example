# Copy to .env or pass with:
# docker compose --env-file .env.selfhost -f docker-compose.selfhost.yml up -d --build

POSTGRES_USER=poolsatis
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=poolsatis

POOLSTATIS_ADMIN_PORT=8080
POOLSTATIS_API_PORT=3300
POOLSTATIS_PUBLIC_URL=http://localhost:8080

DATABASE_POOL_MAX=10
INGEST_BUFFER_MAX_EVENTS=1000
INGEST_BUFFER_MAX_DELAY_MS=10
INGEST_BUFFER_MAX_PENDING_EVENTS=50000

# Keep false until the public MCP package/runner is actually published.
POOLSTATIS_MCP_PACKAGE_PUBLISHED=false
